{% comment %} Ladiesse AI Search Bar v4 — Claude AI powered {% endcomment %}

{% assign body_font = section.settings.custom_font | default: 'inherit' %}

<div id="ladiesse-ai-wrap" style="
  background: {{ section.settings.background_color }};
  border-bottom: 1px solid rgba(0,0,0,0.08);
  padding: {{ section.settings.padding_vertical }}px 24px;
  position: relative;
  z-index: 100;
  font-family: {{ body_font }};
">

  {% if section.settings.show_brand_label %}
    <div style="
      text-align:center;
      font-size:10px;
      letter-spacing:0.22em;
      text-transform:uppercase;
      color: {{ section.settings.label_color }};
      margin-bottom:10px;
      font-family: {{ body_font }};
    ">{{ section.settings.label_text }}</div>
  {% endif %}

  <div style="max-width:720px; margin:0 auto; display:flex; gap:10px; align-items:center;">
    <input
      id="lai-input"
      type="text"
      placeholder="{{ section.settings.placeholder_text }}"
      style="
        flex:1; border:1px solid rgba(0,0,0,0.15);
        border-radius:var(--inputs-radius,4px);
        padding:11px 16px;
        font-family:{{ body_font }};
        font-size:14px;
        background:{{ section.settings.input_background }};
        color:{{ section.settings.text_color }};
        outline:none; width:100%; box-sizing:border-box; transition:border-color 0.2s;
      "
      onfocus="this.style.borderColor='rgba(0,0,0,0.4)'"
      onblur="this.style.borderColor='rgba(0,0,0,0.15)'"
    />
    <button onclick="laiSearch()" id="lai-btn" style="
      background:{{ section.settings.button_background }};
      color:{{ section.settings.button_text_color }};
      border:1px solid {{ section.settings.button_background }};
      border-radius:var(--buttons-radius,4px);
      padding:11px 22px;
      font-family:{{ body_font }};
      font-size:13px; font-weight:500; letter-spacing:0.05em;
      cursor:pointer; white-space:nowrap; transition:opacity 0.2s;
    "
    onmouseover="this.style.opacity='0.8'"
    onmouseout="this.style.opacity='1'">
      {{ section.settings.button_text }}
    </button>
  </div>

  {% if section.settings.show_chips %}
    <div style="max-width:720px; margin:8px auto 0; display:flex; flex-wrap:wrap; gap:6px;">
      {% assign chips = section.settings.suggestion_chips | split: ',' %}
      {% for chip in chips %}
        <span onclick="document.getElementById('lai-input').value='{{ chip | strip }}'; laiSearch();"
          style="
            font-size:12px; padding:4px 14px;
            border:1px solid rgba(0,0,0,0.15); border-radius:20px;
            color:{{ section.settings.chip_text_color }}; cursor:pointer;
            background:transparent; font-family:{{ body_font }};
            letter-spacing:0.02em; transition:border-color 0.2s;
          "
          onmouseover="this.style.borderColor='rgba(0,0,0,0.5)'"
          onmouseout="this.style.borderColor='rgba(0,0,0,0.15)'"
        >{{ chip | strip }}</span>
      {% endfor %}
    </div>
  {% endif %}

  <div id="lai-results" style="max-width:720px; margin:0 auto; display:none;">
    <div id="lai-message" style="
      background:rgba(0,0,0,0.03); border-left:2px solid rgba(0,0,0,0.12);
      border-radius:4px; padding:10px 14px; margin-top:14px;
      font-size:13px; color:{{ section.settings.text_color }};
      opacity:0.75; line-height:1.6; font-family:{{ body_font }}; font-style:italic;
    "></div>
    <div id="lai-grid" style="
      display:grid; grid-template-columns:repeat(auto-fill,minmax(155px,1fr));
      gap:14px; margin-top:14px; padding-bottom:8px;
    "></div>
    <div id="lai-fallback" style="display:none; margin-top:12px; text-align:center;">
      <a href="/collections/all" style="
        font-size:12px; color:{{ section.settings.text_color }};
        opacity:0.6; text-decoration:underline; font-family:{{ body_font }};
      ">Browse all products instead →</a>
    </div>
  </div>
</div>

<script>
(function() {

  // ── REPLACE THIS with your Vercel URL after deploying ──────────────────────
  var API_URL = 'YOUR_VERCEL_URL_HERE/api/search';
  // ──────────────────────────────────────────────────────────────────────────

  var CACHE_KEY = 'lai_products_v1';
  var CACHE_TTL = 5 * 60 * 1000; // 5 minutes

  // Fallback keyword engine (runs if API is unavailable)
  var SYNONYMS = {
    "flowy":["flowy","wrap","slip","maxi","ruffle","midi","linen","relaxed","tiered","airy"],
    "dress":["dress"],"gown":["dress","evening","maxi","lace","luxury","formal"],
    "gift":["gift"],"friend":["gift"],"her":["gift","feminine","flowy","dress"],
    "office":["office","work","blazer","professional","tailored"],
    "vacation":["vacation","travel","linen","casual","beach","summer","resort"],
    "beach":["beach","vacation","summer","flowy","casual","maxi"],
    "evening":["evening","party","elegant","luxe","silk","formal","cocktail"],
    "date":["evening","romantic","feminine","flowy","sexy","party"],
    "boho":["boho","floral","wrap","maxi","relaxed","tiered"],
    "casual":["casual","linen","relaxed","easy","vacation","everyday"],
    "maxi":["maxi","long"],"midi":["midi"],"mini":["mini","short"],
    "romantic":["romantic","feminine","lace","ruffle","flowy","floral"],
    "summer":["summer","vacation","beach","casual","floral","light","breezy"],
    "wedding":["wedding","formal","lace","romantic","elegant","maxi","midi"],
    "jumpsuit":["jumpsuit","romper","playsuit"],
    "floral":["floral","flower","print","botanical"],
    "white":["white","ivory","cream"],"black":["black","noir"],
    "blue":["blue","navy","cobalt"],"pink":["pink","blush","rose"],
  };
  var STOP = {"for":1,"the":1,"and":1,"with":1,"that":1,"this":1,"are":1,"was":1,
    "buy":1,"get":1,"find":1,"want":1,"need":1,"looking":1,"something":1,
    "please":1,"could":1,"would":1,"like":1,"best":1,"good":1,"nice":1,
    "great":1,"beautiful":1,"pretty":1,"cute":1,"some":1,"any":1,
    "my":1,"me":1,"him":1,"she":1,"he":1,"they":1,"we":1,"you":1,"a":1,"as":1};

  function parseBudget(q) {
    var min=0,max=Infinity,m;
    if((m=q.match(/\$(\d+)\s*[-–to]+\s*\$?(\d+)/i)))              {min=+m[1];max=+m[2];}
    else if((m=q.match(/between\s+\$?(\d+)\s+and\s+\$?(\d+)/i)))  {min=+m[1];max=+m[2];}
    else if((m=q.match(/(under|below|up to|at most)\s+\$?(\d+)/i))){max=+m[2];}
    else if((m=q.match(/(over|above|at least|more than)\s+\$?(\d+)/i))){min=+m[2];}
    return {min:min,max:max};
  }

  function extractKeywords(q) {
    var words=q.toLowerCase().replace(/[^a-z0-9\s]/g,' ').split(/\s+/);
    var kw={};
    words.forEach(function(w){
      if(w.length<2||STOP[w])return;
      kw[w]=1;
      if(SYNONYMS[w])SYNONYMS[w].forEach(function(s){kw[s]=1;});
    });
    return kw;
  }

  function stripHtml(html) {
    var d = document.createElement('div');
    d.innerHTML = html;
    return (d.textContent || d.innerText || '').replace(/\s+/g, ' ').trim();
  }

  // Trim a raw Shopify product down to what we store/send
  function normalizeProduct(p) {
    return {
      handle: p.handle,
      title: p.title,
      vendor: p.vendor,
      product_type: p.product_type || '',
      tags: p.tags || [],
      images: (p.images || []).slice(0, 1),
      variants: (p.variants || []).map(function(v) {
        return { price: v.price, available: v.available };
      }),
      desc: p.body_html ? stripHtml(p.body_html).slice(0, 200) : ''
    };
  }

  function getCachedProducts() {
    try {
      var raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      var obj = JSON.parse(raw);
      if (Date.now() - obj.ts > CACHE_TTL) return null;
      return obj.products;
    } catch(e) { return null; }
  }

  function setCachedProducts(products) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), products: products }));
    } catch(e) {}
  }

  function scoreFallback(p,kw,min,max){
    var price=parseFloat(p.variants[0].price);
    if(price<min||price>max)return -1;
    var blob=[(p.tags||[]).join(' '),p.title,p.vendor,p.product_type,p.desc||''].join(' ').toLowerCase();
    var score=0;
    Object.keys(kw).forEach(function(k){if(blob.indexOf(k)!==-1)score+=2;});
    return score;
  }

  // Fetch all pages of products, normalize, then cache
  function fetchAllProducts(cb) {
    var cached = getCachedProducts();
    if (cached) { cb(null, cached); return; }

    var all = [];
    var page = 1;
    var MAX_PAGES = 10; // up to 2500 products

    function fetchPage() {
      fetch('/collections/all/products.json?limit=250&page=' + page)
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var batch = (d.products || []).map(normalizeProduct);
          all = all.concat(batch);
          if (d.products.length === 250 && page < MAX_PAGES) {
            page++;
            fetchPage();
          } else {
            setCachedProducts(all);
            cb(null, all);
          }
        })
        .catch(function(e) {
          if (all.length) cb(null, all);
          else cb(e, []);
        });
    }

    fetchPage();
  }

  // Pre-score the full catalog and return the top 250 candidates for Claude.
  // Filters sold-out items and respects any budget constraint in the query.
  // Puts keyword-matching products first so Claude sees the best candidates.
  function prescoreForClaude(products, q) {
    var budget = parseBudget(q);
    var kw = extractKeywords(q);
    var scored = products
      .filter(function(p) {
        return p.variants && p.variants.some(function(v) { return v.available; });
      })
      .map(function(p) { return { p: p, score: scoreFallback(p, kw, budget.min, budget.max) }; })
      .filter(function(x) { return x.score >= 0; }); // drop out-of-budget
    scored.sort(function(a, b) { return b.score - a.score; });
    return scored.slice(0, 250).map(function(x) { return x.p; });
  }

  function renderCard(p){
    var price=parseFloat(p.variants[0].price).toFixed(2);
    var img=p.images&&p.images[0]?p.images[0].src:'';
    var imgHtml=img
      ?'<img src="'+img+'" alt="'+p.title+'" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">'
      :'<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;">👗</div>';
    return '<a href="/products/'+p.handle+'" style="text-decoration:none;color:inherit;display:block;">'
      +'<div style="border:1px solid rgba(0,0,0,0.08);border-radius:var(--media-radius,4px);overflow:hidden;transition:border-color 0.2s;" '
      +'onmouseover="this.style.borderColor=\'rgba(0,0,0,0.3)\'" onmouseout="this.style.borderColor=\'rgba(0,0,0,0.08)\'">'
      +'<div style="aspect-ratio:3/4;background:#f5f5f5;overflow:hidden;">'+imgHtml+'</div>'
      +'<div style="padding:10px 12px;">'
      +'<div style="font-size:10px;letter-spacing:0.12em;text-transform:uppercase;opacity:0.45;margin-bottom:3px;">'+p.vendor+'</div>'
      +'<div style="font-family:var(--font-heading-family,Georgia,serif);font-size:13px;line-height:1.3;margin-bottom:5px;">'+p.title+'</div>'
      +'<div style="font-size:13px;font-weight:500;">$'+price+'</div>'
      +'</div></div></a>';
  }

  var LOADING_MSGS = [
    "Ooh, let me find something fabulous for you…",
    "Searching for your next obsession…",
    "Curating your perfect look…",
    "On it — this is going to be good…",
    "Our AI stylist is on the case ✨"
  ];

  function setMessage(msg){ document.getElementById('lai-message').innerHTML=msg; }
  function setGrid(html){ document.getElementById('lai-grid').innerHTML=html; }
  function showResults(){ document.getElementById('lai-results').style.display='block'; }
  function showFallback(show){ document.getElementById('lai-fallback').style.display=show?'block':'none'; }

  window.laiSearch = function(){
    var q=document.getElementById('lai-input').value.trim();
    if(!q)return;

    var btn=document.getElementById('lai-btn');
    btn.disabled=true;
    btn.style.opacity='0.5';
    showResults();
    showFallback(false);
    setMessage('✦ '+LOADING_MSGS[Math.floor(Math.random()*LOADING_MSGS.length)]);
    setGrid('');

    fetchAllProducts(function(err,products){
      if(err||!products.length){
        setMessage('✦ Something went sideways — try again in a sec 💫');
        btn.disabled=false; btn.style.opacity='1';
        return;
      }

      if(API_URL.indexOf('YOUR_VERCEL_URL_HERE')===-1){
        var candidates = prescoreForClaude(products, q);
        fetch(API_URL,{
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({query:q,products:candidates})
        })
        .then(function(r){return r.json();})
        .then(function(data){
          btn.disabled=false; btn.style.opacity='1';
          setMessage('✦ '+(data.message||'Here\'s what we found for you.'));
          if(!data.handles||!data.handles.length){
            showFallback(true);
            return;
          }
          var matched=data.handles
            .map(function(h){return products.find(function(p){return p.handle===h;});})
            .filter(Boolean);
          if(!matched.length){ showFallback(true); return; }
          setGrid(matched.map(renderCard).join(''));
        })
        .catch(function(){
          runFallback(q,products);
          btn.disabled=false; btn.style.opacity='1';
        });
      } else {
        runFallback(q,products);
        btn.disabled=false; btn.style.opacity='1';
      }
    });
  };

  function runFallback(q,products){
    var budget=parseBudget(q);
    var kw=extractKeywords(q);
    var scored=products
      .map(function(p){return{p:p,score:scoreFallback(p,kw,budget.min,budget.max)};})
      .filter(function(x){return x.score>0;})
      .sort(function(a,b){return b.score-a.score;})
      .slice(0,8).map(function(x){return x.p;});
    if(!scored.length){
      setMessage('✦ Hmm, nothing jumped out for that one. Try different words or loosen the budget — we have more than you think ✨');
      showFallback(true);
      return;
    }
    var budgetStr=budget.max<Infinity?(budget.min>0?' between $'+budget.min+'–$'+budget.max:' under $'+budget.max):'';
    setMessage('✦ Here are '+scored.length+' pieces we think you\'ll love'+budgetStr+'.');
    setGrid(scored.map(renderCard).join(''));
  }

  document.getElementById('lai-input').addEventListener('keydown',function(e){
    if(e.key==='Enter')window.laiSearch();
  });

})();
</script>

{% schema %}
{
  "name": "AI Search Bar",
  "tag": "div",
  "class": "ladiesse-ai-search",
  "settings": [
    { "type": "header", "content": "Font" },
    {
      "type": "select", "id": "custom_font", "label": "Font family",
      "options": [
        { "value": "inherit", "label": "Same as theme (default)" },
        { "value": "'DM Sans', sans-serif", "label": "DM Sans" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "'Playfair Display', serif", "label": "Playfair Display" },
        { "value": "'Cormorant Garamond', serif", "label": "Cormorant Garamond" },
        { "value": "'Josefin Sans', sans-serif", "label": "Josefin Sans" },
        { "value": "'Raleway', sans-serif", "label": "Raleway" },
        { "value": "'Poppins', sans-serif", "label": "Poppins" },
        { "value": "Georgia, serif", "label": "Georgia (system serif)" }
      ],
      "default": "inherit"
    },
    { "type": "header", "content": "Copy & Labels" },
    { "type": "text", "id": "label_text", "label": "Top label text", "default": "Discover with AI" },
    { "type": "text", "id": "placeholder_text", "label": "Search placeholder", "default": "Tell me what you're dreaming of — style, vibe, budget, occasion…" },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Find It ✦" },
    { "type": "checkbox", "id": "show_brand_label", "label": "Show top label", "default": true },
    { "type": "checkbox", "id": "show_chips", "label": "Show suggestion chips", "default": true },
    { "type": "text", "id": "suggestion_chips", "label": "Suggestion chips (comma-separated)", "default": "Something flirty & flowy, A gift for my girl, Beach vacation vibes, Date night dress, Office but make it chic" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FAFAF8" },
    { "type": "color", "id": "input_background", "label": "Input field background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "label_color", "label": "Top label color", "default": "#999999" },
    { "type": "color", "id": "chip_text_color", "label": "Chip text color", "default": "#555555" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#FFFFFF" },
    { "type": "header", "content": "Layout" },
    {
      "type": "range", "id": "padding_vertical",
      "min": 8, "max": 48, "step": 2, "unit": "px",
      "label": "Top & bottom padding", "default": 16
    }
  ],
  "presets": [{ "name": "AI Search Bar" }]
}
{% endschema %}
